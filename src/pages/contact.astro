---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | The Musings of Matt Domko">
  <div class="max-w-3xl mx-auto">
    <header class="mb-10">
      <h1 class="text-4xl font-bold mb-4">Get in Touch</h1>
      <p class="text-xl text-gray-600">
        Have a question or want to connect? Feel free to reach out using any of the methods below.
      </p>
    </header>
    <div class="bg-white p-8 rounded-lg shadow-md">
      <h2 class="text-2xl font-semibold mb-6">Contact Information</h2>
      <div class="space-y-6">
        <div class="flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
          </svg>
          <div>
            <h3 class="text-lg font-medium mb-1">LinkedIn</h3>
            <a href="https://linkedin.com/in/matthewdomko" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">linkedin.com/in/matthewdomko</a>
          </div>
        </div>
        <div class="flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <div>
            <h3 class="text-lg font-medium mb-1">Email</h3>
            <a href="mailto:blog@totallylegitsite.com" class="text-primary hover:underline">blog@totallylegitsite.com</a>
          </div>
        </div>
        <div class="flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
          <div>
            <h3 class="text-lg font-medium mb-1">GitHub</h3>
            <a href="https://github.com/hashtagcyber" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">github.com/hashtagcyber</a>
          </div>
        </div>
      </div>
      <div class="mt-10 pt-8 border-t border-gray-200">
        <h2 class="text-2xl font-semibold mb-4">Response Time</h2>
        <p class="text-gray-700">
          I typically respond to inquiries within 1-2 business days. As weird as it sounds, LinkedIn is the best way to reach me.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
