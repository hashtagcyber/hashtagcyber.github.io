---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Tools | The Musings of Matt Domko">
  <div class="max-w-4xl mx-auto">
    <header class="mb-10">
      <h1 class="text-4xl font-bold mb-4">Tools</h1>
      <p class="text-xl text-gray-600">
        Useful interactive tools and resources to help you in your professional journey.
      </p>
    </header>
    <div class="grid md:grid-cols-2 gap-6"></div>
    <div class="mt-10 bg-white p-8 rounded-lg shadow-md">
      <h2 class="text-2xl font-semibold mb-4">How to Use These Tools</h2>
      <p class="text-gray-600 mb-4">
        These tools are standalone web applications that you can use directly in your browser. Simply
        click on any tool card above to access it. No installation or login required.
      </p>
      <p class="text-gray-600">
        All tools run entirely in your browser and don&rsquo;t send any data to external servers...
        they&rsquo;re more for me, but I&rsquo;m happy to share.
      </p>
    </div>
  </div>
</BaseLayout>
