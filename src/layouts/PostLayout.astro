---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  collection: 'leadership' | 'security' | 'talks';
}

const { title, description, pubDate, tags, collection } = Astro.props;

const collectionLabel = {
  leadership: 'Leadership',
  security: 'Security',
  talks: 'Talks',
}[collection];

const dateLabel = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'America/Chicago',
});
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto">
    <div class="mb-8">
      <a href={`/${collection}`} class="text-sm text-primary hover:underline">
        &larr; Back to {collectionLabel}
      </a>
    </div>
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-2">{title}</h1>
      <div class="text-gray-600 mb-4">
        <time datetime={pubDate.toISOString()}>{dateLabel}</time>
      </div>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="bg-gray-100 text-gray-800 text-xs px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
