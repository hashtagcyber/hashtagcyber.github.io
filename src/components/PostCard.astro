---
interface Props {
  href: string;
  title: string;
  description?: string;
  pubDate: Date;
}

const { href, title, description, pubDate } = Astro.props;
const dateLabel = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'America/Chicago',
});
---

<article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
  <div class="p-6">
    <div class="text-gray-500 text-sm mb-2">
      <time datetime={pubDate.toISOString()}>{dateLabel}</time>
    </div>
    <h3 class="text-xl font-semibold mb-2">
      <a href={href} class="text-gray-900 hover:text-primary">{title}</a>
    </h3>
    {description && <p class="text-gray-600 mb-4">{description}</p>}
    <a href={href} class="text-primary hover:underline font-medium">Read more &rarr;</a>
  </div>
</article>
