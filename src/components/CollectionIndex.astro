---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from './PostCard.astro';
import type { CollectionEntry } from 'astro:content';

type Coll = 'leadership' | 'security' | 'talks';

interface Props {
  pageTitle: string;
  pageHeading: string;
  lead: string;
  collection: Coll;
  entries: CollectionEntry<Coll>[];
}

const { pageTitle, pageHeading, lead, collection, entries } = Astro.props;
const sorted = [...entries].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={pageTitle}>
  <div class="max-w-4xl mx-auto">
    <header class="mb-10">
      <h1 class="text-4xl font-bold mb-4">{pageHeading}</h1>
      <p class="text-xl text-gray-600">{lead}</p>
    </header>
    <div class="grid gap-8">
      {sorted.map((entry) => (
        <PostCard
          href={`/${collection}/posts/${entry.slug}`}
          title={entry.data.title}
          description={entry.data.description}
          pubDate={entry.data.pubDate}
        />
      ))}
    </div>
  </div>
</BaseLayout>
